# Supabase — copy to .env.local and fill in from your Supabase project settings
# (Project Settings → API)
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# 한국천문연구원 특일정보 API (공공데이터포털 — 무료, 디코딩 키 사용)
VITE_HOLIDAY_API_KEY=your-holiday-api-key

# Base path for the deployed site. Local dev can use "/".
# For GitHub Pages project sites this must match the repo name, e.g. "/PickTime/".
# VITE_BASE=/PickTime/
